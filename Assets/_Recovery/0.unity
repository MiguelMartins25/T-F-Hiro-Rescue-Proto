      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 8988164318199248913, guid: 54e157492bc1847d5aed63927d37b536, type: 3}
      propertyPath: m_Name
      value: Player
      objectReference: {fileID: 0}
